{
  "name": "playwright-bdd-test",
  "version": "1.0.0",
  "description": "Playwright + Cucumber.js BDD framework",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js",
    "test:headed": "powershell -Command \"$env:HEADLESS='false'; cucumber-js\"",
    "test:orangehrm": "cucumber-js --tags @OrangeHRMLogin",
    "test:ecommerce": "cucumber-js --tags @EcommerceFlow",
    "test:smoke": "cucumber-js --tags @smoke"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^10.9.0",
    "@cucumber/pretty-formatter": "^2.1.0",
    "@playwright/test": "^1.55.0",
    "chai": "^6.0.1",
    "dotenv": "^16.6.1",
    "playwright": "^1.55.0",
    "pretty-format": "^30.0.5"
  }
}
